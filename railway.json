{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "preDeployCommand": [
      "php artisan migrate --force && php artisan db:seed --force"
    ],
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/up",
    "healthcheckTimeout": 100
  }
}
